OPENAI_MODEL="qwen-max-latest"
OPENAI_API_KEY=
OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# RL training / local AlphaZero
RL_DEVICE="auto"               # auto / cpu / cuda / mps
RL_CHECKPOINT_DIR="checkpoints"
RL_LOG_DIR="logs"
RL_RUN_NAME=""                 # 可选：手动命名训练run（留空则自动用时间戳）
RL_TENSORBOARD="0"             # 1=true, 0=false
RL_MIN_MOVES_BEFORE_PASS="30"  # self-play防止过早双pass导致策略塌缩
ALPHAZERO_CHECKPOINT_DIR="checkpoints"  # GUI按棋盘大小自动读取 {dir}/{size}x{size}/best_model.pth
# ALPHAZERO_CHECKPOINT_PATH=""          # 可选：显式指定单个权重文件，优先级高于 ALPHAZERO_CHECKPOINT_DIR
ALPHAZERO_MIN_MOVES_BEFORE_PASS="18"  # GUI中AlphaZero早期不pass（9路推荐18）
